{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "comfy skills *",
  "description": "Output shape for skill management commands.",
  "type": "object",
  "properties": {
    "scope": { "type": "string" },
    "dry_run": { "type": "boolean" },
    "results": { "type": "array" },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "skill": { "type": "string" },
          "kind": { "type": "string" },
          "scope": { "type": "string" },
          "path": { "type": "string" },
          "installed": { "type": "boolean" },
          "state": {
            "type": "string",
            "enum": ["current", "stale", "modified", "missing", "unmanaged"]
          }
        }
      }
    },
    "content": { "type": "string" },
    "skills": { "type": "array" },
    "valid": { "type": "boolean" },
    "name": { "type": "string" },
    "bundled": { "type": "boolean" },
    "path": { "type": "string" }
  }
}
